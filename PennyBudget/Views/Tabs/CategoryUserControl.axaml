<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:PennyBudget.ViewModels"
             x:DataType="vm:CategoryWindowViewModel"
             x:Class="PennyBudget.Views.Tabs.CategoryUserControl">
    <DockPanel>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="4">
            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" Spacing="2">
                <Button Command="{Binding AddCategoryCommand}" Content="Nowa kategoria"/>
                <Button Command="{Binding DeleteCommand}" Content="Usuń"/>
            </StackPanel>
        </Border>

        <DataGrid ItemsSource="{Binding Records}"
                  SelectedItem="{Binding SelectedRecord}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nazwa"    Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Kolor"    Binding="{Binding ColorHex}"/>
                <DataGridCheckBoxColumn Header="Przychód" Binding="{Binding IsIncome}"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>
