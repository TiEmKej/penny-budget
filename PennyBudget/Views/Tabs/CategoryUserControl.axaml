<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:PennyBudget.ViewModels"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="vm:CategoryWindowViewModel"
             x:Class="PennyBudget.Views.Tabs.CategoryUserControl">
    <DockPanel Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="4">
            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" Spacing="2">
                <Button Command="{Binding AddCategoryCommand}" ToolTip.Tip="Nowy wpis">
                    <avalonia:MaterialIcon Kind="Plus" Width="32" Height="32"/>
                </Button>
                <Button Command="{Binding EditCategoryCommand}" ToolTip.Tip="Edytuj">
                    <avalonia:MaterialIcon Kind="Pencil" Width="32" Height="32"/>
                </Button>
                <Button Command="{Binding DeleteCommand}" ToolTip.Tip="Usuń">
                    <avalonia:MaterialIcon Kind="Delete" Width="32" Height="32"/>
                </Button>
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <DataGrid ItemsSource="{Binding Records}"
                      SelectedItem="{Binding SelectedRecord}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nazwa"    Binding="{Binding Name}"     SortMemberPath="Name"/>
                    <DataGridTextColumn Header="Kolor"    Binding="{Binding ColorHex}" SortMemberPath="ColorHex"/>
                    <DataGridCheckBoxColumn Header="Przychód" Binding="{Binding IsIncome}" SortMemberPath="IsIncome"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </DockPanel>
</UserControl>
