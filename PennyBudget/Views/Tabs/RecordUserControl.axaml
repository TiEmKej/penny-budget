<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:PennyBudget.ViewModels"
             xmlns:models="using:PennyBudget.Models"
             xmlns:converters="using:PennyBudget.Converters"
             xmlns:res="using:PennyBudget.Resources"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="vm:RecordsWindowViewModel"
             x:Class="PennyBudget.Views.Tabs.RecordUserControl">
    <UserControl.Resources>
        <converters:IsIncomeToColorConverter x:Key="IsIncomeToColor"/>
    </UserControl.Resources>
    <DockPanel Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="4">
            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" Spacing="2">
                <Button Command="{Binding AddRecordCommand}" ToolTip.Tip="{x:Static res:Strings.BtnAdd}">
                    <materialIcons:MaterialIcon Kind="Plus" Width="32" Height="32"/>
                </Button>
                <Button Command="{Binding EditRecordCommand}" ToolTip.Tip="{x:Static res:Strings.BtnEdit}">
                    <materialIcons:MaterialIcon Kind="Pencil" Width="32" Height="32"/>
                </Button>
                <Button Command="{Binding DeleteCommand}" ToolTip.Tip="{x:Static res:Strings.BtnDelete}">
                    <materialIcons:MaterialIcon Kind="Delete" Width="32" Height="32"/>
                </Button>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <TextBox Text="{Binding SearchText}"
                     PlaceholderText="{x:Static res:Strings.SearchPlaceholder}"
                     Width="300"
                     HorizontalAlignment="Left"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="500"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,1,0"
                    Margin="0">
                <DataGrid ItemsSource="{Binding Records}"
                          SelectedItem="{Binding SelectedRecord}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColDate}"        Binding="{Binding Date, StringFormat=\{0:yyyy-MM-dd\}}"          SortMemberPath="Date"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColCategory}"    Binding="{Binding Category.DisplayName}"                          SortMemberPath="Category.DisplayName"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColDescription}" Binding="{Binding Description}"                                   SortMemberPath="Description"/>
                        <DataGridTemplateColumn Header="{x:Static res:Strings.ColAmount}"  SortMemberPath="Amount">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:FinancialRecord">
                                    <TextBlock Text="{Binding Amount, StringFormat=\{0:0.00\}}"
                                               Foreground="{Binding Category.IsIncome, Converter={StaticResource IsIncomeToColor}}"
                                               VerticalAlignment="Center" Padding="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColAccount}"  Binding="{Binding Account.Name}"                                     SortMemberPath="Account.Name"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColCurrency}" Binding="{Binding Currency}"                                         SortMemberPath="Currency"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColRate}"     Binding="{Binding CurrencyRate, StringFormat=\{0:N\}}"               SortMemberPath="CurrencyRate"/>
                        <DataGridTemplateColumn Header="{x:Static res:Strings.ColPln}"  SortMemberPath="AmountInYourCurrency">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:FinancialRecord">
                                    <TextBlock Text="{Binding AmountInYourCurrency, StringFormat=\{0:0.00\}}"
                                               Foreground="{Binding Category.IsIncome, Converter={StaticResource IsIncomeToColor}}"
                                               VerticalAlignment="Center" Padding="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
                <DataGrid ItemsSource="{Binding CategorySummaries}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static res:Strings.ColCategory}" Binding="{Binding CategoryName}" SortMemberPath="CategoryName"/>
                        <DataGridTemplateColumn Header="{x:Static res:Strings.ColPln}"  SortMemberPath="TotalAmountInPln">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:CategorySummary">
                                    <TextBlock Text="{Binding TotalAmountInPln, StringFormat=\{0:0.00\}}"
                                               Foreground="{Binding IsIncome, Converter={StaticResource IsIncomeToColor}}"
                                               VerticalAlignment="Center" Padding="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </Grid>

    </DockPanel>
</UserControl>
