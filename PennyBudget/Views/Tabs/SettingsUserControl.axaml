<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:PennyBudget.ViewModels"
             xmlns:res="using:PennyBudget.Resources"
             x:DataType="vm:SettingsWindowViewModel"
             x:Class="PennyBudget.Views.Tabs.SettingsUserControl">

    <StackPanel Margin="24" Spacing="16" MaxWidth="400" HorizontalAlignment="Left">

        <TextBlock Text="{x:Static res:Strings.LblSettingsLanguage}" FontSize="16" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding Languages}"
                  SelectedItem="{Binding SelectedLanguage}"
                  DisplayMemberBinding="{Binding DisplayName}"
                  HorizontalAlignment="Stretch"/>

        <TextBlock Text="{x:Static res:Strings.LblSettingsRestart}"
                   IsVisible="{Binding RestartRequired}"
                   Foreground="Orange"
                   TextWrapping="Wrap"/>

    </StackPanel>

</UserControl>
